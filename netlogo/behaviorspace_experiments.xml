<?xml version="1.0" encoding="UTF-8"?>
<!--
  NetLogo 7 imports this via NLogoXMLLoader + LabXMLLoader (not the old DOM LabLoader).
  Metrics and parameter sets MUST be wrapped in <metrics> and <constants>; bare <metric>
  or <enumeratedValueSet> under <experiment> triggers "Unknown BehaviorSpace XML node type".
  Chooser strings: NetLogo literals in value attributes, e.g. value="&quot;other&quot;".
  Tang et al. (2025) grp-SIS: exponential, power law, lognormal recovery (Sec. 2.3).

  Headless runs (scripts/run_pipeline.py) use experiments embedded in virus_simulation.nlogox,
  not this file as the setup file path (NetLogo 7.0.3 headless then throws NoSuchElementException).
  After editing here, merge the <experiments> block into the .nlogox without comments that
  contain two consecutive hyphens.
-->
<experiments>
  <experiment name="01-export-networks" repetitions="1" sequentialRunOrder="true" runMetricsEveryStep="false">
    <setup>set bs-collect-metrics? false
set immunization-strategy "none"
set immunized-fraction 0
setup
export-network-edges (word "../output/edges/edges_" safe-net-label "_" expt-seed ".csv")</setup>
    <go>wait 0</go>
    <exitCondition>true</exitCondition>
    <metrics>
      <metric>safe-net-label</metric>
      <metric>count links</metric>
      <metric>num-nodes</metric>
      <metric>bs-out-mean-degree</metric>
    </metrics>
    <constants>
      <!-- ER-only export for the main study: one $N=2000$ draw per expt-seed (see experiments 05–07). -->
      <enumeratedValueSet variable="interconnection-structure">
        <value value="&quot;other&quot;"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="expt-seed">
        <value value="10001"/>
        <value value="10002"/>
        <value value="10003"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="num-nodes">
        <value value="2000"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="network-type">
        <value value="&quot;Erdos-Renyi (random)&quot;"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="avg-degree">
        <value value="6"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="rewiring-prob">
        <value value="0.07"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="initial-infected">
        <value value="5"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="max-ticks">
        <value value="&quot;3000&quot;"/>
      </enumeratedValueSet>
    </constants>
  </experiment>
  <experiment name="02-threshold-exponential" repetitions="8" sequentialRunOrder="true" runMetricsEveryStep="false">
    <setup>set bs-collect-metrics? true
set bs-prev-samples []
set immunization-strategy "none"
set immunized-fraction 0
set recovery-distribution "exponential"
setup</setup>
    <go>go</go>
    <exitCondition>(ticks &gt;= sim-tick-limit) or (not any? turtles with [state = "infected"])</exitCondition>
    <metrics>
      <metric>bs-out-extinct</metric>
      <metric>bs-out-final-tick</metric>
      <metric>bs-out-late-mean-prevalence</metric>
      <metric>bs-out-tau-sim</metric>
      <metric>bs-out-mean-degree</metric>
    </metrics>
    <constants>
      <enumeratedValueSet variable="interconnection-structure">
        <value value="&quot;Lattice4&quot;"/>
        <value value="&quot;Ring&quot;"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="expt-seed">
        <value value="1001"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="num-nodes">
        <value value="200"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="avg-degree">
        <value value="6"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="rewiring-prob">
        <value value="0.07"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="initial-infected">
        <value value="5"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="recovery-mean">
        <value value="5"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="max-ticks">
        <value value="&quot;3000&quot;"/>
      </enumeratedValueSet>
      <steppedValueSet variable="infection-prob" first="0.02" step="0.03" last="0.56"/>
    </constants>
  </experiment>
