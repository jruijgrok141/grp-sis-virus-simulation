        <value value="&quot;other&quot;"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="network-type">
        <value value="&quot;Erdos-Renyi (random)&quot;"/>
      </enumeratedValueSet>
      <!-- Independent ER draws: same seeds 10001–10003 as in 01-export-networks (edges_ER_*.csv). -->
      <enumeratedValueSet variable="expt-seed">
        <value value="10001"/>
        <value value="10002"/>
        <value value="10003"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="num-nodes">
        <value value="2000"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="avg-degree">
        <value value="6"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="rewiring-prob">
        <!-- unused for ER, keep default value for compatibility -->
        <value value="0.07"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="initial-infected">
        <value value="5"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="recovery-mean">
        <value value="5"/>
      </enumeratedValueSet>
      <enumeratedValueSet variable="max-ticks">
        <value value="&quot;10000&quot;"/>
      </enumeratedValueSet>
      <!-- Fine sweep around beta_pred ≈ 1/(lambda_max * E[W]); step 0.002 on [0.018, 0.056]. -->
      <steppedValueSet variable="infection-prob" first="0.018" step="0.002" last="0.056"/>
    </constants>
  </experiment>
